# Copy this file to .env.local and adjust values as needed.
# .env.local is ignored by git and overrides .env values.

# ── Symfony middleware base URL ──────────────────────────────────
# All ENDPOINTS paths (e.g. /auth/login) are appended to this value.
# Backend routes live under /api, so the base URL must include /api.

# Option A – Backend on the same machine (direct, no proxy):
# VITE_API_URL=http://localhost:8080/api

# Option B – Backend on another laptop in the LAN (via Vite proxy):
# Set VITE_API_URL=/api so requests stay same-origin (no CORS).
# Vite proxy catches /api/* and forwards to API_PROXY_TARGET.
VITE_API_URL=/api
API_PROXY_TARGET=http://192.168.0.171:8080

# ── OpenAPI / Swagger docs ──────────────────────────────────────
# The Symfony middleware exposes its API docs at:
#   http://<backend-host>:8080/api/doc
# Use this as the source of truth for available endpoints & schemas.
